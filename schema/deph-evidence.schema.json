{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emphere.com/schemas/deph-evidence.schema.json",
  "title": "deph evidence report",
  "type": "object",
  "required": ["schema_version", "producer", "image", "source", "test_window", "artifacts"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "producer": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "image": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": ["repository", "ref", "sha", "run_id", "run_attempt"],
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string" },
        "ref": { "type": "string" },
        "sha": { "type": "string" },
        "run_id": { "type": "string" },
        "run_attempt": { "type": "string" }
      }
    },
    "test_window": {
      "type": "object",
      "required": ["command", "working_directory", "started_at", "finished_at", "duration_ms", "exit_code", "log_path"],
      "additionalProperties": true,
      "properties": {
        "command": { "type": ["string", "null"] },
        "working_directory": { "type": "string" },
        "started_at": { "type": ["string", "null"] },
        "finished_at": { "type": ["string", "null"] },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "exit_code": { "type": ["integer", "null"], "minimum": 0 },
        "log_path": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["summary_markdown", "report_json"],
      "additionalProperties": true,
      "properties": {
        "summary_markdown": { "type": "string" },
        "report_json": { "type": "string" }
      }
    }
  }
}
